{
  "name": "paum-gestor-educativo",
  "private": true,
  "version": "0.0.0",
  "description": "Sistema integral de gestion academica para el programa PAUM de la BUAP.",
  "author": "Leonardo Avalos / Juan Pablo Cielo",
  "type": "module",
  "main": "build/electron/main.cjs",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite",
    "server": "tsx server.ts",
    "test-pdf": "tsx test-pdf.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "generate:icons": "node scripts/generate-icons.mjs",
    "build": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build:desktop": "npm run generate:icons && npm run build && npm run build:electron",
    "desktop": "npm run build:desktop && electron-builder install-app-deps && electron .",
    "dist:win": "npm run build:desktop && electron-builder --win portable",
    "preview": "vite preview",
    "clean": "rimraf dist build release",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^37.3.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.11",
    "png-to-ico": "^3.0.1",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "mx.paum.gestor-educativo",
    "productName": "PAUM Gestor Educativo",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "build-resources/icon.png",
        "to": "build-resources/icon.png"
      }
    ],
    "files": [
      "dist/**/*",
      "build/electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "icon": "build-resources/icon.ico",
      "artifactName": "PAUM-Gestor-Educativo-${version}-${arch}.${ext}"
    }
  }
}
